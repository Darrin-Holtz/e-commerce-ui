{
  "name": "e-commerce-ui",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=@e-commerce-ui/admin",
    "dev:client": "turbo run dev --filter=@e-commerce-ui/client",
    "lint": "turbo run lint",
    "lint:admin": "turbo run lint --filter=@e-commerce-ui/admin",
    "lint:client": "turbo run lint --filter=@e-commerce-ui/client",
    "start": "turbo run start",
    "clean": "rm -rf .turbo node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "^5"
  }
}